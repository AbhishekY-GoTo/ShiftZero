# AWS Bedrock
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_PROFILE=your-profile  # Alternative to access keys

# PagerDuty
PAGERDUTY_API_KEY=your_pagerduty_api_key
PAGERDUTY_WEBHOOK_SECRET=your_webhook_secret

# Kubernetes (if not using MCP)
KUBECONFIG=/path/to/.kube/config

# Database
DATABASE_URL=postgresql://shiftzero:password@localhost:5432/shiftzero

# Slack (for escalations)
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_ONCALL_CHANNEL=#oncall-alerts

# Safety Settings (Phase 1)
MAX_AUTO_RESTARTS_PER_HOUR=3
CONFIDENCE_THRESHOLD_AUTO_REMEDIATE=0.85
CONFIDENCE_THRESHOLD_ESCALATE=0.70
DRY_RUN_MODE=false

# Logging
LOG_LEVEL=INFO
